# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY: optional Supabase project credentials
# for persisting workout history/streak data instead of localStorage. Both are
# read client-side via import.meta.env, so the VITE_ prefix is required and
# neither value should ever be a secret service-role key. If either is left
# unset, the app falls back to localStorage automatically (see
# src/services/workoutStorage.ts) — no Supabase project is required to run the app.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
